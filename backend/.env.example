APP_NAME=VMS-X Adaptive Visual Memory Intelligence Platform
APP_ENV=development
APP_DEBUG=true
API_PREFIX=/api/v1
DATABASE_URL=sqlite+aiosqlite:///./storage/database/vmsx.db
JWT_SECRET_KEY=replace-with-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://127.0.0.1:4200
MAX_UPLOAD_SIZE_MB=1024

STORAGE_ROOT=./storage
# Optional display-only host path for API responses; file I/O still uses STORAGE_ROOT.
VMS_HOST_STORAGE_ROOT=
YOLO_MODEL_PATH=./storage/models/skysealand_yolo12m_best.onnx
SKYDET_MODEL_PATH=./storage/models/skydet_skysealand_best.pt
IMAGE_TILED_DETECTION_ENABLED=true
IMAGE_TILE_SIZE=1024
IMAGE_TILE_OVERLAP_RATIO=0.25
IMAGE_TILED_MIN_SIDE=1400
IMAGE_MAX_INFERENCE_SIDE=2560
IMAGE_MAX_SOURCE_PIXELS=300000000
SKYDET_BOX_EXPANSION_RATIO=0.08
YOLO_TRAIN_BASE_MODEL=yolo11n.pt

AI_PROVIDER=hybrid
USE_HUGGINGFACE=true
HF_TOKEN=
HUGGINGFACE_API_BASE_URL=https://router.huggingface.co/v1
HUGGINGFACE_VISION_MODEL=zai-org/GLM-4.5V:zai-org
HUGGINGFACE_TEXT_MODEL=Qwen/Qwen2.5-7B-Instruct
HUGGINGFACE_VLM_MODEL=zai-org/GLM-4.5V:zai-org
VLM_TIMEOUT_SECONDS=120

USE_OPENAI=false
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-5.5
OPENAI_API_BASE_URL=https://api.openai.com/v1

USE_GEMINI=false
GEMINI_API_KEY=
GEMINI_VISION_MODEL=gemini-2.5-flash
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com

CLOUD_AI_TIMEOUT_SECONDS=60
CLOUD_AI_MAX_RETRIES=2
CLOUD_AI_HYBRID_ORDER=huggingface,gemini,openai
